---
import Layout from '../layouts/Layout.astro';
const title = "Jual Asxone 138 SL & Produk Pertanian Kalimantan";
const description = "Toko Tani Green Al Fatih: jual herbisida, fungisida, insektisida, pupuk, dan kebutuhan tani di Kalimantan. Pengiriman ke seluruh Kalimantan. Order via WhatsApp.";
---

<Layout title={title} description={description}>
  <!-- Hero -->
  <section class="bg-gradient-to-br from-green-800 via-green-700 to-emerald-800 text-white py-20 px-4 text-center">
    <h1 class="text-4xl md:text-5xl font-bold mb-4">Solusi Pertanian Terpercaya</h1>
    <p class="text-xl text-green-100 max-w-2xl mx-auto mb-8">Toko Tani Green Al Fatih menyediakan herbisida, fungisida, insektisida, pupuk, dan kebutuhan tani lengkap untuk petani Kalimantan.</p>
    <div class="flex gap-4 justify-center flex-wrap">
      <a href="https://wa.me/6285251988382" class="bg-green-500 hover:bg-green-400 text-white px-8 py-4 rounded-full text-lg font-bold transition shadow-lg">
        💬 Order via WhatsApp
      </a>
      <a href="/produk" class="bg-white/20 hover:bg-white/30 text-white border border-white/40 px-8 py-4 rounded-full text-lg font-medium transition">
        Lihat Produk →
      </a>
    </div>
  </section>

  <!-- Features -->
  <section class="py-16 px-4 max-w-6xl mx-auto">
    <h2 class="text-3xl font-bold text-center mb-12">Kenapa Toko Tani Green Al Fatih?</h2>
    <div class="grid md:grid-cols-3 gap-8">
      <div class="text-center p-6 rounded-xl bg-green-50">
        <div class="text-4xl mb-3">🚚</div>
        <h3 class="font-bold text-lg mb-2">Pengiriman Seluruh Kalimantan</h3>
        <p class="text-gray-600 text-sm">Kami kirim ke Kalteng, Kaltim, Kalbar, Kalsel, Kaltara, dan seluruh wilayah Kalimantan.</p>
      </div>
      <div class="text-center p-6 rounded-xl bg-green-50">
        <div class="text-4xl mb-3">🏷️</div>
        <h3 class="font-bold text-lg mb-2">Harga Kompetitif</h3>
        <p class="text-gray-600 text-sm">Harga langsung dari distributor, cocok untuk petani, pengecer, dan grosir.</p>
      </div>
      <div class="text-center p-6 rounded-xl bg-green-50">
        <div class="text-4xl mb-3">💬</div>
        <h3 class="font-bold text-lg mb-2">Konsultasi Gratis</h3>
        <p class="text-gray-600 text-sm">Bingung pilih produk? Tanya langsung via WhatsApp, kami bantu rekomendasi.</p>
      </div>
    </div>
  </section>

  <!-- Products preview -->
  <section class="py-16 px-4 bg-gray-50">
    <div class="max-w-6xl mx-auto">
      <h2 class="text-3xl font-bold text-center mb-4">Produk Unggulan</h2>
      <p class="text-center text-gray-500 mb-12 max-w-xl mx-auto">Kami menyediakan berbagai produk pertanian berkualitas untuk kebutuhan petani Kalimantan.</p>
      <div class="grid md:grid-cols-4 gap-6">
        <div class="bg-white rounded-xl p-6 text-center shadow-sm hover:shadow-md transition">
          <div class="text-4xl mb-3">🧪</div>
          <h3 class="font-bold mb-1">Asxone 138 SL</h3>
          <p class="text-sm text-gray-500">Herbisida sistemik untuk gulma berdaun lebar</p>
        </div>
        <div class="bg-white rounded-xl p-6 text-center shadow-sm hover:shadow-md transition">
          <div class="text-4xl mb-3">🛡️</div>
          <h3 class="font-bold mb-1">Copcide 77 WP</h3>
          <p class="text-sm text-gray-500">Fungisida protektif untuk tanaman pangan</p>
        </div>
        <div class="bg-white rounded-xl p-6 text-center shadow-sm hover:shadow-md transition">
          <div class="text-4xl mb-3">🌱</div>
          <h3 class="font-bold mb-1">Pupuk Organik</h3>
          <p class="text-sm text-gray-500">Pupuk lengkap untuk semua jenis tanaman</p>
        </div>
        <div class="bg-white rounded-xl p-6 text-center shadow-sm hover:shadow-md transition">
          <div class="text-4xl mb-3">🐛</div>
          <h3 class="font-bold mb-1">Insektisida</h3>
          <p class="text-sm text-gray-500">Pengendali hama tanaman efektif</p>
        </div>
      </div>
      <div class="text-center mt-10">
        <a href="/produk" class="inline-block bg-green-700 hover:bg-green-800 text-white px-8 py-3 rounded-full font-medium transition">
          Lihat Semua Produk →
        </a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 px-4 bg-gradient-to-r from-green-700 to-emerald-700 text-white text-center">
    <h2 class="text-3xl font-bold mb-4">Siap Panen Lebih Baik?</h2>
    <p class="text-xl text-green-100 mb-8 max-w-xl mx-auto">Hubungi kami sekarang untuk info harga dan pemesanan. Gratis konsultasi!</p>
    <a href="https://wa.me/6285251988382" class="inline-block bg-white text-green-800 px-10 py-4 rounded-full text-lg font-bold hover:bg-green-50 transition shadow-lg">
      💬 Chat WhatsApp Sekarang
    </a>
  </section>
</Layout>

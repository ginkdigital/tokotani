---
import Layout from '../layouts/Layout.astro';
const title = "Produk - Toko Tani Kalteng Green Al Fatih";
const description = "Asxone 138 SL: herbisida kontak purna tumbuh. Sekali semprot, gulma mati 24 jam. Panen naik, hasil berlipat. Kirim seluruh Kalimantan.";
---
<Layout breadcrumb={[{label: 'Produk'}]} title={title} description={description}>
  <!-- Clean Hero -->
  <section class="bg-gradient-to-br from-green-800 via-green-700 to-emerald-800 text-white py-12 sm:py-16 px-4 text-center reveal">
    <h1 class="text-2xl sm:text-4xl font-bold mb-3">Asxone 138 SL</h1>
    <p class="text-green-100 text-base sm:text-lg max-w-xl mx-auto">Herbisida kontak purna tumbuh. Sekali semprot, gulma mati total. Panen Anda, hasil berlipat.</p>
  </section>

  <section class="py-10 sm:py-16 px-4 max-w-3xl mx-auto">
    <!-- Product Card -->
    <div class="bg-white border rounded-2xl p-5 sm:p-8 shadow-sm max-w-lg mx-auto mb-10 reveal">
      <img src="/images/Toko-Tani-Green-Al-Fatih-Asxone-138-SL.webp" alt="Asxone 138 SL" class="w-full rounded-xl mb-5" loading="lazy" />
      <h2 class="text-2xl font-bold mb-2">Asxone 138 SL</h2>
      <span class="inline-block bg-green-100 text-green-800 text-xs font-bold px-3 py-1 rounded-full mb-3">Best Seller</span>
      
      <p class="text-gray-700 mb-4"><strong class="text-green-800">Bahan aktif:</strong> Paraquat diklorida 276 g/l  ,  konsentrasi tertinggi.</p>
      <p class="text-gray-700 mb-4"><strong class="text-green-800">Takaran:</strong> 2,3 ml per liter air. Satu botol 1 liter cukup 2,4 hektar.</p>
      <p class="text-gray-700 mb-4"><strong class="text-green-800">Hasil:</strong> 2 jam daun mulai layu. 24 jam mati total. Sekali semprot, lahan bersih.</p>

      <div class="article-table-wrapper mb-5">
        <table class="article-table">
          <thead><tr><th>Tanpa Asxone</th><th>Dengan Asxone</th></tr></thead>
          <tbody>
            <tr><td>Semprot 3x  ,  masih ada gulma</td><td>Sekali semprot  ,  minggu depan bersih</td></tr>
            <tr><td>Panen turun  ,  hasil jual sedikit</td><td>Panen maksimal  ,  duit lebih banyak</td></tr>
            <tr><td>Beli herbisida terus  ,  boncos</td><td>Satu botol 2-4 hektar  ,  hemat</td></tr>
          </tbody>
        </table>
      </div>

      <a href="https://wa.me/6285251988382?text=Halo%2C%20saya%20mau%20order%20Asxone%20138%20SL" class="block text-center bg-green-600 hover:bg-green-700 text-white py-3 rounded-full font-bold transition pulse-cta">💬 Order Sekarang  ,  0852-5198-8382</a>

    <!-- BenBi Hook -->
    <div class="text-center mb-10 reveal">
      <h2 class="text-xl sm:text-2xl font-bold mb-2">Gulma Hilang, Panen Naik, Duit Masuk</h2>
      <p class="text-gray-500 max-w-lg mx-auto text-sm">Bukan salah lahan. Bukan salah bibit. Masalahnya cuma satu: herbisida Anda terlalu lemah. Asxone = investasi, bukan biaya.</p>

---
import Layout from '../layouts/Layout.astro';
const title = "Produk - Toko Tani Kalteng Green Al Fatih";
const description = "Asxone 138 SL: herbisida kontak purna tumbuh. Sekali semprot, gulma mati total — panen maksimal, hasil berlipat. Kirim seluruh Kalimantan.";
---

<Layout title={title} description={description}>
  <!-- Hero -->
  <section class="bg-gradient-to-br from-green-800 via-green-700 to-emerald-800 text-white py-12 sm:py-16 md:py-20 px-4 text-center reveal">
    <h1 class="text-2xl sm:text-3xl md:text-5xl font-bold mb-3">Lihat Tetangga Panen 2x Lipat — Anda Masih Berjuang Lawan Gulma?</h1>
    <p class="text-green-100 text-base sm:text-lg max-w-2xl mx-auto">Bukan salah lahan. Bukan salah bibit. Masalahnya cuma satu: herbisida Anda terlalu lemah.</p>
  </section>

  <!-- Product Image + The Hook -->
  <div class="max-w-2xl mx-auto -mt-8 px-4 relative z-10 reveal">
    <img src="/images/Toko-Tani-Green-Al-Fatih-Asxone-138-SL.webp" alt="Asxone 138 SL" class="w-full rounded-2xl shadow-2xl" loading="lazy" />
  </div>

  <section class="py-10 sm:py-16 px-4 max-w-3xl mx-auto">
    
    <!-- BenBi Chain: Dari Gulma → Duit → Status -->

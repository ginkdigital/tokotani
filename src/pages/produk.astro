---
import Layout from '../layouts/Layout.astro';
const title = "Produk - Toko Tani Kalteng Green Al Fatih";
const description = "Asxone 138 SL: herbisida sistemik berkualitas untuk petani Kalimantan. Tersedia pengiriman ke seluruh Kalimantan.";
---

<Layout title={title} description={description}>
  <section class="py-16 px-4 max-w-3xl mx-auto">
    <h1 class="text-4xl font-bold text-center mb-4">Produk Kami</h1>
    <p class="text-center text-gray-500 mb-12 max-w-2xl mx-auto">Kami menyediakan produk pertanian berkualitas untuk kebutuhan petani Kalimantan.</p>
    
    <!-- Produk Utama -->
    <div class="bg-white border rounded-2xl p-6 md:p-8 shadow-sm max-w-lg mx-auto mb-12">
      <img src="/images/jual-asxone-138-SL-pangkalan-banteng-1024x576.webp" alt="Asxone 138 SL" class="w-full rounded-xl mb-4" loading="lazy" />
      <h2 class="text-2xl font-bold mb-2">Asxone 138 SL</h2>
      <span class="inline-block bg-green-100 text-green-800 text-xs font-bold px-3 py-1 rounded-full mb-3">Best Seller</span>
      <p class="text-gray-600 mb-4">Herbisida sistemik berkualitas tinggi untuk mengendalikan gulma berdaun lebar pada tanaman padi, jagung, kelapa sawit, dan tanaman perkebunan lainnya.</p>
      <ul class="text-sm text-gray-500 space-y-1 mb-6">
        <li>✅ Bahan aktif 138 g/l — efektif untuk gulma resisten</li>
        <li>✅ Sistemik — menyerap hingga ke akar gulma</li>
        <li>✅ Tersedia berbagai ukuran kemasan</li>
        <li>✅ Harga grosir tersedia</li>
      </ul>
      <a href="https://wa.me/6285251988382?text=Halo%2C%20saya%20mau%20tanya%20harga%20Asxone%20138%20SL" class="inline-block bg-green-600 hover:bg-green-700 text-white px-6 py-3 rounded-full font-medium transition text-sm">💬 Tanya Harga Asxone</a>
    </div>

    <!-- Area Tersedia -->
    <div class="text-center mb-8">
      <h2 class="text-2xl font-bold mb-2">Tersedia di Seluruh Kalimantan</h2>
      <p class="text-gray-500 mb-6">Klik kota Anda untuk info detail:</p>
      <div class="grid grid-cols-2 md:grid-cols-3 gap-3">
        <a href="/blog/jual-asxone-138-sl-kalimantan-tengah" class="bg-green-50 hover:bg-green-100 rounded-lg px-4 py-3 text-green-800 font-medium transition text-sm text-center">Kalimantan Tengah</a>
        <a href="/blog/jual-asxone-138-sl-kalimantan-barat" class="bg-green-50 hover:bg-green-100 rounded-lg px-4 py-3 text-green-800 font-medium transition text-sm text-center">Kalimantan Barat</a>
        <a href="/blog/jual-asxone-138-sl-kalimantan-selatan" class="bg-green-50 hover:bg-green-100 rounded-lg px-4 py-3 text-green-800 font-medium transition text-sm text-center">Kalimantan Selatan</a>
        <a href="/blog/jual-asxone-138-sl-kalimantan-timur" class="bg-green-50 hover:bg-green-100 rounded-lg px-4 py-3 text-green-800 font-medium transition text-sm text-center">Kalimantan Timur</a>
        <a href="/blog/jual-asxone-138-sl-kalimantan-utara" class="bg-green-50 hover:bg-green-100 rounded-lg px-4 py-3 text-green-800 font-medium transition text-sm text-center">Kalimantan Utara</a>
        <a href="/blog/jual-asxone-138-sl-sampit" class="bg-green-50 hover:bg-green-100 rounded-lg px-4 py-3 text-green-800 font-medium transition text-sm text-center">Sampit</a>
        <a href="/blog/jual-asxone-138-sl-pangkalan-bun" class="bg-green-50 hover:bg-green-100 rounded-lg px-4 py-3 text-green-800 font-medium transition text-sm text-center">Pangkalan Bun</a>
        <a href="/blog/jual-asxone-138-sl-pangkalan-banteng" class="bg-green-50 hover:bg-green-100 rounded-lg px-4 py-3 text-green-800 font-medium transition text-sm text-center">Pangkalan Banteng</a>
        <a href="/blog/jual-asxone-138-sl-sukamara" class="bg-green-50 hover:bg-green-100 rounded-lg px-4 py-3 text-green-800 font-medium transition text-sm text-center">Sukamara</a>
        <a href="/blog/jual-asxone-138-sl-seruyan" class="bg-green-50 hover:bg-green-100 rounded-lg px-4 py-3 text-green-800 font-medium transition text-sm text-center">Seruyan</a>
        <a href="/blog/beli-asxone-138-sl-pangkalan-banteng" class="bg-green-50 hover:bg-green-100 rounded-lg px-4 py-3 text-green-800 font-medium transition text-sm text-center">Cara Beli</a>
        <a href="/pengiriman" class="bg-green-50 hover:bg-green-100 rounded-lg px-4 py-3 text-green-800 font-medium transition text-sm text-center">Info Pengiriman →</a>
      </div>
    </div>

    <div class="text-center bg-green-50 rounded-2xl p-8">
      <p class="text-lg mb-3">🤝 Butuh info lebih lanjut?</p>
      <p class="text-gray-500 mb-4">Hubungi kami langsung — kami siap bantu kebutuhan pertanian Anda.</p>
      <a href="https://wa.me/6285251988382" class="inline-block bg-green-600 hover:bg-green-700 text-white px-8 py-3 rounded-full font-bold transition">💬 Chat WhatsApp</a>
    </div>
  </section>
</Layout>

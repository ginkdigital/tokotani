---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import { marked } from 'marked';

marked.setOptions({ gfm: true, breaks: true });

function renderBody(text) {
  if (!text) return '';
  text = text.replace(/By\s*\n+\s*Gink Digital\s*\/\s*\n+\s*\w+ \d+, \d+/g, '');
  text = text.replace(/📑 Daftar Isi[\s\S]*?(?=## )/, '');
  text = text.replace(/💡 Ringkasan\n+/g, '');
  
  let html = marked.parse(text);
  
  html = html.replace(/<h2/g, '<h2 class="article-h2"');
  html = html.replace(/<h3/g, '<h3 class="article-h3"');
  html = html.replace(/<ul/g, '<ul class="article-ul"');
  html = html.replace(/<ol/g, '<ol class="article-ol"');
  html = html.replace(/<blockquote/g, '<blockquote class="article-bq"');
  html = html.replace(/<table/g, '<div class="article-table-wrapper"><table class="article-table"');
  html = html.replace(/<\/table>/g, '</table></div>');
  html = html.replace(/<strong/g, '<strong class="article-strong"');
  
  let h2Count = 0;
  html = html.replace(/<h2 class="article-h2"/g, (match) => {
    h2Count++;
    if (h2Count === 3) {
      return `<div class="article-cta">
  <p class="text-sm opacity-90 mb-1">Butuh Asxone 138 SL?</p>
  <a href="https://wa.me/6285251988382" class="inline-block bg-green-500 hover:bg-green-400 text-white px-5 py-2 rounded-full text-sm font-bold transition">💬 Order via WhatsApp</a>
</div>` + match;
    }
    return match;
  });
  
  return html;
}

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const htmlContent = renderBody(post.body || '');

// Sidebar area links
const areaLinks = [
  { label: 'Kalimantan Tengah', href: '/blog/jual-asxone-138-sl-kalimantan-tengah' },
  { label: 'Kalimantan Barat', href: '/blog/jual-asxone-138-sl-kalimantan-barat' },
  { label: 'Kalimantan Selatan', href: '/blog/jual-asxone-138-sl-kalimantan-selatan' },
  { label: 'Kalimantan Timur', href: '/blog/jual-asxone-138-sl-kalimantan-timur' },
  { label: 'Kalimantan Utara', href: '/blog/jual-asxone-138-sl-kalimantan-utara' },
  { label: 'Sampit', href: '/blog/jual-asxone-138-sl-sampit' },
  { label: 'Pangkalan Bun', href: '/blog/jual-asxone-138-sl-pangkalan-bun' },
  { label: 'Pangkalan Banteng', href: '/blog/jual-asxone-138-sl-pangkalan-banteng' },
  { label: 'Sukamara', href: '/blog/jual-asxone-138-sl-sukamara' },
  { label: 'Seruyan', href: '/blog/jual-asxone-138-sl-seruyan' },
];
---

<Layout title={post.data.title} description={post.data.description} breadcrumb={[{label: "Artikel", href: "/blog"}, {label: post.data.title}]}>
  <div id="progress-bar" class="fixed top-0 left-0 h-1 bg-green-500 z-[60] transition-all duration-150" style="width:0%"></div>

  <div class="max-w-6xl mx-auto px-4 py-8 sm:py-12 md:py-16">
    <div class="flex flex-col md:flex-row gap-8 lg:gap-12">
      
      <!-- ARTICLE (left) -->
      <article class="flex-1 min-w-0">
        <!-- Share buttons (horizontal on mobile, sticky left on desktop) -->
        <div class="flex md:hidden justify-center gap-3 mb-6">
          <a href={`https://wa.me/?text=${encodeURIComponent(post.data.title + ' ' + Astro.url.href)}`} target="_blank" class="flex items-center gap-1 bg-green-600 text-white px-4 py-2 rounded-full text-sm font-medium hover:bg-green-700 transition">💬 Share WA</a>
          <a href={`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(Astro.url.href)}`} target="_blank" class="flex items-center gap-1 bg-blue-600 text-white px-4 py-2 rounded-full text-sm font-medium hover:bg-blue-700 transition">📘 Share FB</a>
          <button onclick={`navigator.clipboard.writeText('${Astro.url.href}')`} class="flex items-center gap-1 bg-gray-600 text-white px-4 py-2 rounded-full text-sm font-medium hover:bg-gray-700 transition">🔗 Copy</button>
        </div>

        <!-- Sticky share bar (desktop left) -->
        <div class="hidden md:block fixed left-4 lg:left-8 top-1/2 -translate-y-1/2 space-y-2 z-40">
          <a href={`https://wa.me/?text=${encodeURIComponent(post.data.title + ' ' + Astro.url.href)}`} target="_blank" class="block w-10 h-10 bg-green-600 hover:bg-green-700 text-white rounded-full flex items-center justify-center text-lg transition shadow-lg" title="Share WhatsApp">💬</a>
          <a href={`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(Astro.url.href)}`} target="_blank" class="block w-10 h-10 bg-blue-600 hover:bg-blue-700 text-white rounded-full flex items-center justify-center text-lg transition shadow-lg" title="Share Facebook">📘</a>
          <button onclick={`navigator.clipboard.writeText('${Astro.url.href}')`} class="block w-10 h-10 bg-gray-600 hover:bg-gray-700 text-white rounded-full flex items-center justify-center text-lg transition shadow-lg" title="Copy Link">🔗</button>
        </div>

        <header class="mb-8 text-center">
          <h1 class="text-2xl sm:text-3xl md:text-4xl font-bold mb-3 leading-tight">{post.data.title}</h1>
          <p class="text-gray-500 text-base sm:text-lg max-w-xl mx-auto">{post.data.description}</p>
        </header>

        <nav class="bg-gray-50 rounded-xl p-4 mb-10 text-sm" id="toc">
          <details class="md:hidden">
            <summary class="font-bold cursor-pointer text-green-800">📑 Daftar Isi</summary>
            <div class="mt-2 space-y-1" id="toc-mobile"></div>
          </details>
          <div class="hidden md:block">
            <div class="font-bold mb-2 text-xs uppercase tracking-wide text-gray-400">Daftar Isi</div>
            <div class="space-y-1" id="toc-desktop"></div>
          </div>
        </nav>

        <div class="article-body" id="article-content">
          <Fragment set:html={htmlContent} />
        </div>

        <footer class="mt-12 pt-8 border-t text-center md:hidden">
          <p class="text-gray-500 text-sm mb-4">Butuh produk? Hubungi kami sekarang:</p>
          <a href="https://wa.me/6285251988382" class="inline-block bg-green-600 hover:bg-green-700 text-white px-8 py-3 rounded-full font-bold transition text-sm pulse-cta">💬 Chat WhatsApp</a>
        </footer>
      </article>

      <!-- SIDEBAR (right) -->
      <aside class="md:w-72 lg:w-80 shrink-0">
        <div class="md:sticky md:top-24 space-y-5">

          <!-- Order Card -->
          <div class="bg-white border rounded-2xl p-5 shadow-sm text-center">
            <div class="text-4xl mb-2">🧪</div>
            <h3 class="font-bold text-lg mb-1">Asxone 138 SL</h3>
            <p class="text-xs text-gray-500 mb-3">Herbisida Kontak Purna Tumbuh</p>
            <a href="https://wa.me/6285251988382?text=Halo%2C%20saya%20mau%20order%20Asxone%20138%20SL" class="block bg-green-600 hover:bg-green-700 text-white py-3 px-4 rounded-full font-bold transition text-sm mb-2">💬 Order Sekarang</a>
            <p class="text-xs text-gray-400">📞 0852-5198-8382</p>
          </div>

          <!-- Area Pengiriman -->
          <div class="bg-white border rounded-2xl p-5 shadow-sm">
            <h3 class="font-bold text-sm mb-3 flex items-center gap-2">📍 Area Pengiriman</h3>
            <div class="space-y-0.5 text-sm max-h-64 overflow-y-auto">
              {areaLinks.map(link => (
                <a href={link.href} class="block py-1.5 px-2 rounded-lg text-gray-600 hover:bg-green-50 hover:text-green-700 transition text-sm">
                  {link.label}
                </a>
              ))}
              <a href="/pengiriman" class="block py-1.5 px-2 rounded-lg text-green-700 font-medium hover:bg-green-50 transition text-sm">Selengkapnya →</a>
            </div>
          </div>

          <!-- Jam Operasional -->
          <div class="bg-white border rounded-2xl p-5 shadow-sm text-sm">
            <h3 class="font-bold mb-3 flex items-center gap-2">🕐 Jam Operasional</h3>
            <div class="space-y-1 text-gray-600">
              <p class="flex justify-between"><span>Senin - Sabtu</span> <span class="font-medium">08.00 - 17.00</span></p>
              <p class="flex justify-between"><span>Minggu</span> <span class="text-red-500">Tutup</span></p>
            </div>
          </div>

          <!-- Google Maps -->
          <div class="bg-white border rounded-2xl p-5 shadow-sm text-sm text-center">
            <p class="text-gray-600 mb-2">📍 Pangkalan Banteng, Kalteng</p>
            <a href="https://maps.app.goo.gl/AGGdMgXS8a7JY6Qb9" target="_blank" class="inline-block bg-gray-100 hover:bg-gray-200 text-gray-700 px-4 py-2 rounded-lg font-medium transition text-sm">🗺️ Buka Google Maps</a>
          </div>

          <!-- CTA Footer (desktop) -->
          <div class="hidden md:block text-center pt-2">
            <a href="https://wa.me/6285251988382" class="inline-block bg-green-600 hover:bg-green-700 text-white px-6 py-3 rounded-full font-bold transition text-sm pulse-cta w-full">💬 Chat WhatsApp</a>
          </div>

        </div>
      </aside>

    </div>
  </div>
</Layout>

<style is:global>
.article-body {
  font-size: 17px;
  line-height: 1.85;
  color: #1a1a1a;
}
.article-body p { margin-bottom: 1.25rem; }

.article-h2 {
  font-family: 'Fraunces', serif;
  font-size: clamp(1.4rem, 3vw, 1.7rem);
  font-weight: 600;
  color: #14532d;
  margin-top: 3rem;
  margin-bottom: 1rem;
  padding-bottom: 0.5rem;
  border-bottom: 2px solid #dcfce7;
}
.article-h3 {
  font-family: 'Fraunces', serif;
  font-size: 1.15rem;
  font-weight: 600;
  color: #1e293b;
  margin-top: 2rem;
  margin-bottom: 0.75rem;
}

.article-ul, .article-ol { margin-bottom: 1.5rem; padding-left: 0; }
.article-ol { padding-left: 1.5rem; }
.article-ul li, .article-ol li { margin-bottom: 0.75rem; padding: 0.5rem 0; }
.article-ul { list-style: none; }
.article-ul li {
  padding: 0.6rem 0 0.6rem 2rem;
  position: relative;
  border-bottom: 1px solid #f0fdf4;
}
.article-ul li:last-child { border-bottom: none; }
.article-ul li::before {
  content: "✓";
  position: absolute;
  left: 0.25rem;
  top: 0.6rem;
  color: #22c55e;
  font-weight: 700;
  font-size: 0.9rem;
}

.article-strong { color: #15803d; font-weight: 600; }

.article-bq {
  background: #f0fdf4;
  border-left: 4px solid #22c55e;
  border-radius: 0 12px 12px 0;
  padding: 1rem 1.25rem;
  margin: 1.5rem 0;
  font-style: italic;
  color: #374151;
}

.article-table-wrapper { overflow-x: auto; margin: 1.5rem 0; border-radius: 12px; border: 1px solid #dcfce7; }
.article-table { width: 100%; border-collapse: collapse; font-size: 0.9rem; }
.article-table thead { background: #f0fdf4; }
.article-table th { 
  color: #14532d; 
  padding: 0.9rem 1rem; 
  text-align: left; 
  font-weight: 600; 
  font-size: 0.85rem;
  text-transform: uppercase;
  letter-spacing: 0.03em;
  border-bottom: 2px solid #bbf7d0;
}
.article-table td { 
  padding: 0.8rem 1rem; 
  border-bottom: 1px solid #f0fdf4; 
  color: #374151;
}
.article-table tr:last-child td { border-bottom: none; }
.article-table tbody tr:hover { background: #f9fafb; }
.article-table td:first-child { color: #6b7280; }
.article-table td:last-child { color: #14532d; font-weight: 500; }

hr { border: none; height: 1px; background: linear-gradient(90deg, transparent, #e2e8f0, transparent); margin: 2.5rem 0; }

.article-cta {
  background: linear-gradient(135deg, #166534, #15803d);
  color: white;
  border-radius: 12px;
  padding: 1rem 1.5rem;
  margin: 2rem 0;
  text-align: center;
}

@media (max-width: 768px) {
  .article-body { font-size: 16px; }
  .article-h2 { font-size: 1.25rem; }
}
</style>

<script>
  window.addEventListener('scroll', () => {
    const s = document.documentElement.scrollTop;
    const h = document.documentElement.scrollHeight - window.innerHeight;
    document.getElementById('progress-bar').style.width = Math.min(100, (s/h)*100) + '%';
  });

  document.addEventListener('DOMContentLoaded', () => {
    const h2s = document.querySelectorAll('.article-h2');
    const tocD = document.getElementById('toc-desktop');
    const tocM = document.getElementById('toc-mobile');
    h2s.forEach((h2, i) => {
      h2.id = 'section-' + i;
      const link = `<a href="#section-${i}" class="block text-green-700 hover:underline py-0.5">${h2.textContent}</a>`;
      if (tocD) tocD.innerHTML += link;
      if (tocM) tocM.innerHTML += link;
    });
    if (h2s.length === 0) document.getElementById('toc').style.display = 'none';
  });
</script>

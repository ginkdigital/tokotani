---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.id },
    props: { post },
  }));
}

function renderBody(text) {
  if (!text) return '';
  
  // Clean WP artifacts
  let lines = text.split('\n');
  let clean = [];
  let skip = false;
  
  for (let line of lines) {
    let trimmed = line.trim();
    if (!trimmed) { clean.push(''); continue; }
    
    // Skip WP metadata lines
    if (/^By\s*$/i.test(trimmed)) { skip = true; continue; }
    if (skip && /^(Gink Digital|\/|\w+ \d+, \d+)$/i.test(trimmed)) continue;
    skip = false;
    
    // Headings
    if (/^#{1,3}\s/.test(trimmed)) {
      let level = trimmed.match(/^(#{1,3})/)[0].length;
      let content = trimmed.replace(/^#{1,3}\s*/, '');
      clean.push(`<h${level}>${content}</h${level}>`);
      continue;
    }
    
    // Horizontal rule
    if (trimmed === '---') { clean.push('<hr>'); continue; }
    
    // Bold
    trimmed = trimmed.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>');
    // Links
    trimmed = trimmed.replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2" class="text-green-700 hover:underline">$1</a>');
    
    clean.push(trimmed);
  }
  
  // Group into paragraphs by blank lines
  let html = '';
  let para = [];
  for (let line of clean) {
    if (line === '') {
      if (para.length > 0) {
        html += '<p>' + para.join(' ') + '</p>\n';
        para = [];
      }
    } else if (line.startsWith('<')) {
      if (para.length > 0) { html += '<p>' + para.join(' ') + '</p>\n'; para = []; }
      html += line + '\n';
    } else {
      para.push(line);
    }
  }
  if (para.length > 0) html += '<p>' + para.join(' ') + '</p>';
  
  return html;
}

const { post } = Astro.props;
const htmlContent = renderBody(post.body || '');
---

<Layout title={post.data.title} description={post.data.description}>
  <article class="py-8 sm:py-12 md:py-16 px-4 max-w-2xl mx-auto">
    <header class="mb-8 text-center">
      <h1 class="text-2xl sm:text-3xl md:text-4xl font-bold mb-3 leading-tight">{post.data.title}</h1>
      <p class="text-gray-500 text-base sm:text-lg max-w-xl mx-auto">{post.data.description}</p>
    </header>
    <div class="prose prose-sm sm:prose max-w-none text-gray-700 leading-relaxed space-y-4">
      <style>
        .blog-content p { margin-bottom: 1.25rem; }
        .blog-content h2 { margin-top: 2.5rem; margin-bottom: 1rem; }
        .blog-content h3 { margin-top: 2rem; margin-bottom: 0.75rem; }
        .blog-content hr { margin: 2.5rem 0; }
        .blog-content ul, .blog-content ol { margin-bottom: 1.25rem; padding-left: 1.5rem; }
        .blog-content li { margin-bottom: 0.5rem; }
        .blog-content img { margin: 1.5rem 0; }
      </style>
      <div class="blog-content">
      <Fragment set:html={htmlContent} />
      </div>
    </div>
    <footer class="mt-12 pt-8 border-t text-center">
      <p class="text-gray-500 text-sm mb-4">Butuh produk? Hubungi kami sekarang:</p>
      <a href="https://wa.me/6285251988382" class="inline-block bg-green-600 hover:bg-green-700 text-white px-8 py-3 rounded-full font-bold transition text-sm pulse-cta">
        💬 Chat WhatsApp
      </a>
    </footer>
  </article>
</Layout>

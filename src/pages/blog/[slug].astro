---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import { marked } from 'marked';

marked.setOptions({ gfm: true, breaks: true });

function renderBody(text) {
  if (!text) return '';
  // Clean WP artifacts
  text = text.replace(/By\s*\n+\s*Gink Digital\s*\/\s*\n+\s*\w+ \d+, \d+/g, '');
  text = text.replace(/📑 Daftar Isi[\s\S]*?(?=## )/, ''); // remove WP toc
  text = text.replace(/💡 Ringkasan\n+/g, '');
  
  let html = marked.parse(text);
  
  // Post-process: add classes
  html = html.replace(/<h2/g, '<h2 class="article-h2"');
  html = html.replace(/<h3/g, '<h3 class="article-h3"');
  html = html.replace(/<ul/g, '<ul class="article-ul"');
  html = html.replace(/<ol/g, '<ol class="article-ol"');
  html = html.replace(/<blockquote/g, '<blockquote class="article-bq"');
  html = html.replace(/<table/g, '<div class="overflow-x-auto"><table class="article-table"');
  html = html.replace(/<\/table>/g, '</table></div>');
  html = html.replace(/<strong/g, '<strong class="article-strong"');
  
  // Inject CTA mid-content (after 3rd H2 section)
  let h2Count = 0;
  html = html.replace(/<h2 class="article-h2"/g, (match) => {
    h2Count++;
    if (h2Count === 3) {
      return `<div class="article-cta">
  <p class="text-sm opacity-90 mb-1">Butuh Asxone 138 SL?</p>
  <a href="https://wa.me/6285251988382" class="inline-block bg-green-500 hover:bg-green-400 text-white px-5 py-2 rounded-full text-sm font-bold transition">💬 Order via WhatsApp</a>
</div>` + match;
    }
    return match;
  });
  
  return html;
}

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const htmlContent = renderBody(post.body || '');
---

<Layout title={post.data.title} description={post.data.description}>
  <!-- Reading progress bar -->
  <div id="progress-bar" class="fixed top-0 left-0 h-1 bg-green-500 z-[60] transition-all duration-150" style="width:0%"></div>

  <article class="py-8 sm:py-12 md:py-16 px-4 max-w-2xl mx-auto">
    <!-- Header -->
    <header class="mb-8 text-center">
      <h1 class="text-2xl sm:text-3xl md:text-4xl font-bold mb-3 leading-tight">{post.data.title}</h1>
      <p class="text-gray-500 text-base sm:text-lg max-w-xl mx-auto">{post.data.description}</p>
    </header>

    <!-- Table of Contents -->
    <nav class="bg-gray-50 rounded-xl p-4 mb-10 text-sm" id="toc">
      <details class="md:hidden">
        <summary class="font-bold cursor-pointer text-green-800">📑 Daftar Isi</summary>
        <div class="mt-2 space-y-1" id="toc-mobile"></div>
      </details>
      <div class="hidden md:block">
        <div class="font-bold mb-2 text-xs uppercase tracking-wide text-gray-400">Daftar Isi</div>
        <div class="space-y-1" id="toc-desktop"></div>
      </div>
    </nav>

    <!-- Article body -->
    <div class="article-body" id="article-content">
      <Fragment set:html={htmlContent} />
    </div>

    <!-- Footer CTA -->
    <footer class="mt-12 pt-8 border-t text-center">
      <p class="text-gray-500 text-sm mb-4">Butuh produk? Hubungi kami sekarang:</p>
      <a href="https://wa.me/6285251988382" class="inline-block bg-green-600 hover:bg-green-700 text-white px-8 py-3 rounded-full font-bold transition text-sm pulse-cta">
        💬 Chat WhatsApp
      </a>
    </footer>
  </article>
</Layout>

<!-- Styles -->
<style>
.article-body {
  font-size: 17px;
  line-height: 1.85;
  color: #1a1a1a;
}
.article-body p { margin-bottom: 1.25rem; }

.article-h2 {
  font-family: 'Fraunces', serif;
  font-size: clamp(1.4rem, 3vw, 1.7rem);
  font-weight: 600;
  color: #14532d;
  margin-top: 2.5rem;
  margin-bottom: 1rem;
  padding-bottom: 0.5rem;
  border-bottom: 2px solid #dcfce7;
}
.article-h3 {
  font-family: 'Fraunces', serif;
  font-size: 1.15rem;
  font-weight: 600;
  color: #1e293b;
  margin-top: 2rem;
  margin-bottom: 0.75rem;
}

.article-ul, .article-ol { margin-bottom: 1.25rem; padding-left: 1.5rem; }
.article-ul li, .article-ol li { margin-bottom: 0.5rem; }
.article-ul { list-style: none; padding-left: 0; }
.article-ul li {
  padding-left: 1.75rem;
  position: relative;
}
.article-ul li::before {
  content: "✓";
  position: absolute;
  left: 0;
  color: #22c55e;
  font-weight: 700;
}

.article-strong { color: #15803d; font-weight: 600; }

.article-bq {
  background: #f0fdf4;
  border-left: 4px solid #22c55e;
  border-radius: 0 12px 12px 0;
  padding: 1rem 1.25rem;
  margin: 1.5rem 0;
  font-style: italic;
  color: #374151;
}

.article-table { width: 100%; border-collapse: collapse; margin: 1.5rem 0; font-size: 0.9rem; }
.article-table th { background: #f0fdf4; color: #14532d; padding: 0.75rem; text-align: left; font-weight: 600; }
.article-table td { padding: 0.75rem; border-bottom: 1px solid #e2e8f0; }

hr { border: none; height: 1px; background: linear-gradient(90deg, transparent, #e2e8f0, transparent); margin: 2.5rem 0; }

.article-cta {
  background: linear-gradient(135deg, #166534, #15803d);
  color: white;
  border-radius: 12px;
  padding: 1rem 1.5rem;
  margin: 2rem 0;
  text-align: center;
}

@media (max-width: 640px) {
  .article-body { font-size: 16px; }
  .article-h2 { font-size: 1.25rem; }
}
</style>

<!-- Scripts -->
<script>
  // Reading progress
  window.addEventListener('scroll', () => {
    const s = document.documentElement.scrollTop;
    const h = document.documentElement.scrollHeight - window.innerHeight;
    document.getElementById('progress-bar').style.width = Math.min(100, (s/h)*100) + '%';
  });

  // Auto-generate TOC
  document.addEventListener('DOMContentLoaded', () => {
    const h2s = document.querySelectorAll('.article-h2');
    const tocD = document.getElementById('toc-desktop');
    const tocM = document.getElementById('toc-mobile');
    h2s.forEach((h2, i) => {
      h2.id = 'section-' + i;
      const link = `<a href="#section-${i}" class="block text-green-700 hover:underline py-0.5">${h2.textContent}</a>`;
      if (tocD) tocD.innerHTML += link;
      if (tocM) tocM.innerHTML += link;
    });
    // Hide TOC if no H2s
    if (h2s.length === 0) document.getElementById('toc').style.display = 'none';
  });
</script>

---
import Layout from '../layouts/Layout.astro';
const title = "Area Pengiriman - Toko Tani Kalteng Green Al Fatih";
const description = "Toko Tani Green Al Fatih melayani pengiriman Asxone 138 SL ke seluruh Kalimantan: Kalteng, Kalbar, Kalsel, Kaltim, Kaltara, dan kota-kota sekitarnya.";
const regions = [
  { label: 'Kalimantan Tengah', href: '/blog/jual-asxone-138-sl-kalimantan-tengah', cities: 'Pangkalan Banteng, Pangkalan Bun, Sampit, Palangkaraya', icon: '🌴' },
  { label: 'Kalimantan Barat', href: '/blog/jual-asxone-138-sl-kalimantan-barat', cities: 'Pontianak, Ketapang, Sintang, Singkawang', icon: '🏞️' },
  { label: 'Kalimantan Selatan', href: '/blog/jual-asxone-138-sl-kalimantan-selatan', cities: 'Banjarmasin, Banjarbaru, Martapura, Tanah Laut', icon: '🕌' },
  { label: 'Kalimantan Timur', href: '/blog/jual-asxone-138-sl-kalimantan-timur', cities: 'Samarinda, Balikpapan, Kutai, Bontang', icon: '⛰️' },
  { label: 'Kalimantan Utara', href: '/blog/jual-asxone-138-sl-kalimantan-utara', cities: 'Tarakan, Tanjung Selor, Malinau', icon: '🌊' },
  { label: 'Seruyan & Sukamara', href: '/blog/jual-asxone-138-sl-seruyan', cities: 'Kuala Pembuang, Sukamara, dan sekitarnya', icon: '🌿' },
];
const cities = [
  { label: 'Sampit', href: '/blog/jual-asxone-138-sl-sampit' },
  { label: 'Pangkalan Bun', href: '/blog/jual-asxone-138-sl-pangkalan-bun' },
  { label: 'Pangkalan Banteng', href: '/blog/jual-asxone-138-sl-pangkalan-banteng' },
  { label: 'Sukamara', href: '/blog/jual-asxone-138-sl-sukamara' },
];
---

<Layout title={title} description={description}>
  <!-- Hero -->
  <section class="bg-gradient-to-br from-green-800 via-green-700 to-emerald-800 text-white py-12 sm:py-16 md:py-20 px-4 text-center reveal">
    <h1 class="text-2xl sm:text-3xl md:text-5xl font-bold mb-3">Kirim ke Seluruh Kalimantan</h1>
    <p class="text-green-100 text-base sm:text-lg max-w-2xl mx-auto">Dari Pangkalan Banteng  –  kami kirim Asxone 138 SL ke provinsi dan kota Anda. Cepat, aman, via ekspedisi terpercaya.</p>
  </section>

  <section class="py-10 sm:py-16 px-4 max-w-4xl mx-auto">
    
    <!-- Provinsi Grid -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-5 mb-10">
      {regions.map(r => (
        <a href={r.href} class="group bg-white border rounded-2xl p-5 sm:p-6 hover:shadow-lg hover:-translate-y-1 transition-all duration-300 reveal">
          <div class="text-3xl mb-3">{r.icon}</div>
          <h3 class="font-bold text-lg mb-1 text-gray-800 group-hover:text-green-700 transition-colors">{r.label}</h3>
          <p class="text-sm text-gray-500">{r.cities}</p>
          <div class="mt-3 text-green-600 text-sm font-medium group-hover:ml-1 transition-all">Lihat detail →</div>
        </a>
      ))}
    </div>

    <!-- CTA Mid -->
    <div class="text-center bg-green-600 text-white rounded-2xl p-6 sm:p-8 mb-10 reveal">
      <p class="text-lg sm:text-xl font-bold mb-2">🚚 Butuh info ongkir & estimasi pengiriman?</p>
      <p class="text-green-100 text-sm mb-5">Chat kami sekarang  –  kami hitungkan ongkir ke kota Anda.</p>
      <a href="https://wa.me/6285251988382?text=Halo%2C%20saya%20mau%20tanya%20ongkir%20Asxone%20138%20SL%20ke%20kota%20saya" class="inline-block bg-white text-green-800 px-8 py-3 rounded-full font-bold hover:bg-green-50 transition shadow-lg pulse-cta">💬 Cek Ongkir Sekarang</a>
    </div>

    <!-- Kota Spesifik -->
    <h2 class="text-2xl sm:text-3xl font-bold text-center mb-2 reveal">Kota Tujuan</h2>
    <p class="text-center text-gray-500 mb-6 reveal">Klik kota Anda untuk info lengkap:</p>
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-10 reveal">
      {cities.map(c => (
        <a href={c.href} class="hover-lift bg-green-50 hover:bg-green-100 rounded-xl px-4 py-3 text-green-800 font-medium transition text-center text-sm">{c.label}</a>
      ))}
    </div>

    <!-- CTA Footer -->
    <div class="text-center bg-green-50 rounded-2xl p-8 reveal">
      <p class="text-lg font-bold text-green-900 mb-2">Pengiriman ke luar Kalimantan?</p>
      <p class="text-gray-500 mb-5 text-sm">Kami juga melayani pengiriman ke luar Kalimantan via jasa ekspedisi. Hubungi kami untuk info lebih lanjut.</p>
      <a href="https://wa.me/6285251988382" class="inline-block bg-green-600 hover:bg-green-700 text-white px-6 py-3 rounded-full font-bold transition text-sm">💬 Chat WhatsApp</a>
    </div>

  </section>
</Layout>

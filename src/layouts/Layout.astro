---
import '../styles/global.css';
// Layout utama TokoTani
const { title, description } = Astro.props;
---
<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} | Toko Tani Green Al Fatih</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site).href} />
  <link rel="icon" type="image/webp" sizes="32x32" href="/images/cropped-Logo-Green-Al-Fatih-32x32.webp">
  <link rel="icon" type="image/webp" sizes="192x192" href="/images/cropped-Logo-Green-Al-Fatih-192x192.webp">
  <link rel="apple-touch-icon" href="/images/cropped-Logo-Green-Al-Fatih-180x180.webp">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,600;0,9..144,700;1,9..144,400&family=Source+Sans+3:wght@400;500;600&display=swap" rel="stylesheet">
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta name="robots" content="index, follow" />
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "LocalBusiness",
      "name": "Toko Tani Green Al Fatih",
      "description": "Toko pertanian di Pangkalan Banteng, Kalimantan Tengah. Jual herbisida, fungisida, insektisida, pupuk, dan kebutuhan tani.",
      "address": { "@type": "PostalAddress", "addressLocality": "Pangkalan Banteng", "addressRegion": "Kalimantan Tengah" },
      "telephone": "+6285251988382",
      "url": "https://tokotani.avathur.id"
    }
  </script>
</head>
<body class="bg-white text-gray-800" style="font-family: 'Source Sans 3', sans-serif">
  <style is:global>
    h1, h2, h3 { font-family: 'Fraunces', serif; font-weight: 600; }
    h1 { font-size: clamp(2rem, 5vw, 3.5rem); line-height: 1.1; }
    h2 { font-size: clamp(1.5rem, 3vw, 2.5rem); line-height: 1.2; }
    /* Scroll reveal */
    .reveal { opacity: 0; transform: translateY(24px); transition: opacity 0.6s ease-out, transform 0.6s ease-out; }
    .reveal.visible { opacity: 1; transform: translateY(0); }
    /* Hover lift */
    .hover-lift { transition: transform 0.3s ease, box-shadow 0.3s ease; }
    .hover-lift:hover { transform: translateY(-4px); box-shadow: 0 12px 32px rgba(0,0,0,0.08); }
    /* Pulse CTA */
    @keyframes pulse-cta { 0%,100% { box-shadow: 0 4px 16px rgba(22,163,74,0.3); } 50% { box-shadow: 0 8px 32px rgba(22,163,74,0.5); } }
    .pulse-cta { animation: pulse-cta 2.5s ease-in-out infinite; }
  </style>
  <header class="bg-green-800 text-white sticky top-0 z-50 shadow-lg">
    <div class="max-w-6xl mx-auto px-4 py-3 flex items-center justify-between">
      <a href="/" class="flex items-center gap-3 shrink-0">
        <img src="/images/cropped-Logo-Green-Al-Fatih-32x32.webp" alt="Logo" class="w-8 h-8" />
        <div>
          <div class="font-bold text-lg leading-tight">Toko Tani</div>
          <div class="text-xs text-green-200 leading-tight">Green Al Fatih</div>
        </div>
      </a>
      <!-- Desktop nav -->
      <nav class="hidden md:flex gap-6 text-sm font-medium">
        <a href="/" class="hover:text-green-200 transition">Beranda</a>
        <a href="/produk" class="hover:text-green-200 transition">Produk</a>
        <a href="/pengiriman" class="hover:text-green-200 transition">Pengiriman</a>
        <a href="/tentang-kami" class="hover:text-green-200 transition">Tentang</a>
        <a href="/blog" class="hover:text-green-200 transition">Artikel</a>
        <a href="/kontak" class="hover:text-green-200 transition">Kontak</a>
      </nav>
      <!-- WA button (desktop only in header) -->
      <a href="https://wa.me/6285251988382" class="hidden md:flex bg-green-500 hover:bg-green-400 text-white px-4 py-2 rounded-full text-sm font-bold transition items-center gap-2 shrink-0">
        💬 Order WA
      </a>
      <!-- Hamburger (mobile only) -->
      <button id="menu-toggle" class="md:hidden text-white p-2 -mr-2" aria-label="Menu">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
          <line x1="3" y1="6" x2="21" y2="6"></line>
          <line x1="3" y1="12" x2="21" y2="12"></line>
          <line x1="3" y1="18" x2="21" y2="18"></line>
        </svg>
      </button>
    </div>
    <!-- Mobile nav (hidden by default) -->
    <nav id="mobile-menu" class="hidden md:hidden bg-green-700 px-4 pb-4 pt-2 space-y-1">
      <a href="/" class="block py-3 px-3 rounded-lg text-sm font-medium hover:bg-green-600 transition">🏠 Beranda</a>
      <a href="/produk" class="block py-3 px-3 rounded-lg text-sm font-medium hover:bg-green-600 transition">📦 Produk</a>
      <a href="/pengiriman" class="block py-3 px-3 rounded-lg text-sm font-medium hover:bg-green-600 transition">🚚 Pengiriman</a>
      <a href="/tentang-kami" class="block py-3 px-3 rounded-lg text-sm font-medium hover:bg-green-600 transition">🌿 Tentang</a>
      <a href="/blog" class="block py-3 px-3 rounded-lg text-sm font-medium hover:bg-green-600 transition">📝 Artikel</a>
      <a href="/kontak" class="block py-3 px-3 rounded-lg text-sm font-medium hover:bg-green-600 transition">📞 Kontak</a>
    </nav>
  </header>
  <!-- Toggle + Scroll Reveal scripts -->
  <script>
    document.getElementById('menu-toggle').addEventListener('click', function() {
      document.getElementById('mobile-menu').classList.toggle('hidden');
    });
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(e => { if(e.isIntersecting) e.target.classList.add('visible'); });
    }, { threshold: 0.15 });
    document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
  </script>

  <main>
    <slot />
  </main>

  <!-- Footer -->
  <footer class="bg-gray-900 text-gray-400 py-12 mt-16">
    <div class="max-w-6xl mx-auto px-4 grid md:grid-cols-3 gap-8">
      <div>
        <div class="font-bold text-white text-lg mb-2">🌾 Toko Tani Green Al Fatih</div>
        <p class="text-sm">Toko pertanian terpercaya di Kalimantan Tengah. Melayani petani sejak 2020.</p>
      </div>
      <div>
        <div class="font-bold text-white mb-2">Link Cepat</div>
        <div class="flex flex-col gap-1 text-sm">
          <a href="/produk" class="hover:text-white transition">Produk</a>
          <a href="/blog" class="hover:text-white transition">Artikel</a>
          <a href="/pengiriman" class="hover:text-white transition">Area Pengiriman</a>
          <a href="/tentang-kami" class="hover:text-white transition">Tentang Kami</a>
          <a href="/kontak" class="hover:text-white transition">Kontak</a>
        </div>
      </div>
      <div>
        <div class="font-bold text-white mb-2">Hubungi Kami</div>
        <p class="text-sm mb-1">📍 <a href="https://maps.app.goo.gl/?q=Pangkalan+Banteng+Kalimantan+Tengah" target="_blank" class="hover:text-green-300 transition">Pangkalan Banteng, Kalimantan Tengah</a></p>
        <p class="text-sm mb-1">📞 <a href="https://wa.me/6285251988382" class="hover:text-green-300 transition">0852-5198-8382</a></p>
        <p class="text-sm">📧 tokotanigreenalfatih@gmail.com</p>
      </div>
      <div>
        <div class="font-bold text-white mb-2">Ikuti Kami</div>
        <div class="flex gap-3 text-xl">
          <a href="https://www.tiktok.com/@greenalfatih" target="_blank" class="hover:text-white transition" title="TikTok">📱</a>
          <a href="https://www.facebook.com/pages/Toko-Tani-Green-Alfatih/414384105082499/" target="_blank" class="hover:text-white transition" title="Facebook">📘</a>
          <a href="https://www.instagram.com/p/DMoweNE0ghc/" target="_blank" class="hover:text-white transition" title="Instagram">📷</a>
        </div>
        <p class="text-xs text-gray-500 mt-3">@greenalfatih</p>
      </div>
    </div>
    <div class="text-center text-xs mt-8 pt-8 border-t border-gray-800 max-w-6xl mx-auto px-4">
      <p>© 2026 Toko Tani Green Al Fatih. Website dikelola oleh <a href="https://avathur.id" class="text-green-400 hover:underline">WAKi</a> — Website Anti-Kiamat.</p>
    </div>
  </footer>
  <!-- Floating WA FAB (mobile only) -->
  <a href="https://wa.me/6285251988382" class="md:hidden fixed bottom-6 right-4 z-50 bg-green-500 hover:bg-green-400 text-white px-5 py-3 rounded-full shadow-lg font-bold text-sm transition flex items-center gap-2 animate-pulse" style="box-shadow: 0 4px 20px rgba(34,197,94,0.4);">
    💬 Order WA
  </a>
</body>
</html>
